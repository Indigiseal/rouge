{
  "name": "dungeon-card-crawler",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node tools/server.mjs",
    "sim": "node sim/balance-sim.js",
    "sim:loot-stats": "node sim/balance-sim.js loot-stats 100",
    "sim:loot-stats-balance": "node sim/balance-sim.js loot-stats 100 balance --json",
    "sim:stats-db": "node sim/balance-sim.js stats-db",
    "sim:stats-db-balance": "node sim/balance-sim.js stats-db balance",
    "sim:stats-db-fresh": "node sim/balance-sim.js stats-db fresh",
    "sim:stats-db-geared": "node sim/balance-sim.js stats-db geared",
    "sim:stats-db-meta-only": "node sim/balance-sim.js stats-db fresh --meta --no-amulets",
    "sim:stats-db-amulets-only": "node sim/balance-sim.js stats-db fresh --amulets --no-meta",
    "sim:stats-db-full": "node sim/balance-sim.js stats-db geared --amulet-loadout strong",
    "sim:balance-analyze": "node sim/balance-tune.mjs analyze",
    "sim:balance-tune": "node sim/balance-tune.mjs tune",
    "sim:amulet-sweep": "node sim/balance-sim.js sweep",
    "sim:grafana": "bash sim/db/grafana-up.sh",
    "sim:grafana:build": "node sim/db/grafana/build-dashboard.mjs && node sim/db/grafana/build-compare-dashboard.mjs",
    "sim:grafana:down": "docker compose -f sim/db/docker-compose.yml down",
    "sim:grafana:logs": "docker compose -f sim/db/docker-compose.yml logs -f grafana",
    "sim:dashboard": "node tools/stats-dashboard.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
